# copy to .env

# --- Base ---
DATABASE_URL="postgresql://vnzl:vnzl@localhost:5432/insumos?schema=public"
REDIS_URL="redis://localhost:6379"
API_PORT=3001
NEXT_PUBLIC_API_URL="http://localhost:3001"

# --- Auth / sesiones ---
# JWT_SECRET firma TODOS los tokens (sesión de usuario, invitaciones, admin),
# distinguidos por el claim `typ`. En prod: secreto largo y aleatorio.
JWT_SECRET="dev-only-change-me"

# --- Login con Google (OAuth) ---
# Mismo Client ID en API (verificar el ID token) y web (botón). Sin esto, el
# login con Google no se muestra; cédula+contraseña sigue funcionando.
GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# --- CORS (API) ---
# Orígenes del frontend permitidos (coma-separados). Vacío en dev = permite todo.
WEB_ORIGIN=""

# --- Validación de cédula (CEN-23, api.cedula.com.ve) ---
APP_ID_CEDULA=""
TOKEN_CEDULA=""

# --- Pool de Postgres (tier hobby) ---
DB_POOL_MAX="5"

# --- Sentry (errores; opcional, no-op si vacío) ---
SENTRY_DSN=""                 # API
NEXT_PUBLIC_SENTRY_DSN=""     # Web
# SENTRY_ENV / NEXT_PUBLIC_SENTRY_ENV: opcional, default NODE_ENV/VERCEL_ENV
# Subida de source maps en build (web). Sin estas, el build NO falla, solo omite
# la subida (los traces quedan minificados). authToken: secreto de Sentry.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
