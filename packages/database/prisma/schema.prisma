generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL lives in prisma.config.ts (CLI) and the
  // driver adapter (runtime, src/index.ts), not here.
}

model Usuario {
  id           String  @id @default(uuid())
  nombre       String?
  cedula       String? @unique // identificador de login; null hasta completar perfil (Google)
  telefono     String?
  passwordHash String? // null para usuarios solo-Google que no fijaron contraseña
  googleId     String? @unique // sub del ID token de Google
  email        String? @unique // email verificado de Google

  // Validación de cédula contra api.cedula.com.ve (CEN-23).
  cedulaVerificada   Boolean?  @default(false) // null = no se pudo consultar (fail-open, p.ej. Google)
  cedulaNombre       String?
  cedulaVerificadaEn DateTime? // sentinel "ya intentada": null = pendiente de validar

  centros       Voluntario[]
  movimientos   Historial[]
  enviosCreados Envio[]
}

model Centro {
  id          String       @id @default(uuid())
  nombre      String
  estado      String // Ej: Zulia, Miranda...
  ciudad      String // Ej: Maracaibo, Caracas...
  direccion   String
  latitud     Float? // Coordenadas para geolocalización
  longitud    Float?
  // ponytail: estado de recepción toggled a mano por el operador (Activo/Cerrado).
  // Upgrade: derivar de un modelo de horarios (día+hora+timezone) si hace falta.
  recibiendoAhora Boolean   @default(true)
  horarioCierre   String? // "20:00" — solo display, nunca se filtra por él
  creadoEn    DateTime     @default(now())

  // Verificación manual (etiqueta, no portón): el centro opera desde PENDIENTE.
  verificacion EstadoVerificacion @default(PENDIENTE)
  verificadoEn DateTime?
  verificadoPorId String? // qué admin lo verificó (accountability)
  fotoUrl      String? // foto del local/cartel (evidencia para el verificador)
  geoLat       Float? // geo del dispositivo al registrar (vs dirección declarada)
  geoLng       Float?

  voluntarios   Voluntario[]
  insumos       Insumo[]
  enviosOrigen  Envio[] @relation("EnviosOrigen")
  enviosDestino Envio[] @relation("EnviosDestino")
  reportes      Reporte[]
  verificadoPor Admin? @relation(fields: [verificadoPorId], references: [id])

  @@index([estado, ciudad])
  @@index([recibiendoAhora])
}

// Moderador del equipo (verifica centros). Login propio (opción C): email +
// password hasheada → sesión JWT. Da accountability (quién verificó) y revocación
// por persona (activo=false). ponytail: 2 filas sembradas a mano, sin UI de admins.
model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  nombre       String
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  verificaciones Centro[]
}

model Voluntario {
  id         String        @id @default(uuid())
  usuarioId  String
  centroId   String
  rol        RolVoluntario @default(VOLUNTARIO)
  asignadoEn DateTime      @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  centro  Centro  @relation(fields: [centroId], references: [id])

  @@unique([usuarioId, centroId])
}

model Insumo {
  id            String          @id @default(uuid())
  nombre        String
  descripcion   String?
  centroId      String
  cantidadTotal Int             @default(0)
  nivel         NivelInsumo     @default(NORMAL) // color del badge (URGENTE/NORMAL/SUFICIENTE)
  categoria     CategoriaInsumo? // ícono del badge
  // Umbrales opcionales: si AMBOS están seteados, `nivel` se autocalcula desde
  // `cantidadTotal` (<= urgente -> URGENTE, >= suficiente -> SUFICIENTE, medio -> NORMAL).
  // null en cualquiera = sin umbrales = nivel manual. Ver constants/insumos.ts calcularNivel.
  umbralUrgente    Int? // <= -> URGENTE
  umbralSuficiente Int? // >= -> SUFICIENTE

  centro      Centro      @relation(fields: [centroId], references: [id])
  movimientos Historial[]

  @@index([centroId, nivel]) // soporta el filtro "Urgencia Alta"
}

enum NivelInsumo {
  URGENTE
  NORMAL
  SUFICIENTE
}

enum CategoriaInsumo {
  AGUA
  MEDICAMENTOS
  ROPA
  ALIMENTOS
  HERRAMIENTAS
}

enum RolVoluntario {
  JEFE        // creador del centro (dueño)
  VOLUNTARIO  // agregado vía invitación
}

enum EstadoVerificacion {
  PENDIENTE   // recién creado, sin revisar (igual opera)
  VERIFICADO  // el equipo confirmó que existe
  RECHAZADO   // el equipo lo marcó como no legítimo
}

// Motivo por el que un usuario reporta un centro (CEN-22).
enum MotivoReporte {
  NO_EXISTE       // "Ya no está"
  INFO_INCORRECTA // datos incorrectos
  ENGANOSO        // engañoso / falso
}

// Reporte comunitario de un centro inválido. Anónimo: `fingerprint` es el
// dispositivo, SIN FK a Usuario (no exige identidad). 1 por dispositivo por centro.
model Reporte {
  id          String        @id @default(uuid())
  centroId    String
  fingerprint String
  motivo      MotivoReporte
  comentario  String?
  creadoEn    DateTime      @default(now())

  centro Centro @relation(fields: [centroId], references: [id])

  @@unique([centroId, fingerprint])
  @@index([centroId])
}

enum TipoMovimiento {
  DONACION // escaneo de voluntario (default; lo que ya existía)
  CARGA_INICIAL // siembra al crear el centro (autoridad: JEFE creador)
  AJUSTE // corrección manual del JEFE (+/-)
  SALIDA // despacho (envío)
}

model Historial {
  id        String         @id @default(uuid())
  insumoId  String
  usuarioId String
  cantidad  Int // Positivo (entrada) o negativo (salida)
  tipo      TipoMovimiento @default(DONACION)
  envioId   String? // set si el movimiento (-) es parte de un despacho
  fecha     DateTime       @default(now())

  insumo  Insumo  @relation(fields: [insumoId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])
  envio   Envio?  @relation(fields: [envioId], references: [id])

  @@index([insumoId])
  @@index([envioId])
}

// Despacho de insumos de un centro a otro destino (centro de la red o albergue
// de texto libre). "Solo despacho": descuenta el origen vía Historial(-); el
// destino NO suma automático. Ver CEN-16.
model Envio {
  id              String   @id @default(uuid())
  centroOrigenId  String
  centroDestinoId String? // FK a Centro si el destino está en la red
  destinoTexto    String? // albergue / destino libre (si no es un Centro)
  transporte      String // chofer / coordinador (texto)
  creadoPorId     String // voluntario que despachó (registro de quién lo hizo)
  creadoEn        DateTime @default(now())

  origen      Centro      @relation("EnviosOrigen", fields: [centroOrigenId], references: [id])
  destino     Centro?     @relation("EnviosDestino", fields: [centroDestinoId], references: [id])
  creadoPor   Usuario     @relation(fields: [creadoPorId], references: [id])
  movimientos Historial[]

  @@index([centroOrigenId])
}
